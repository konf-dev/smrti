# Smrti Development Configuration
SMRTI_SYSTEM_NAME=smrti-development
SMRTI_ENVIRONMENT=development

# Redis Configuration
SMRTI_REDIS_HOST=localhost
SMRTI_REDIS_PORT=6379

# Security
SMRTI_JWT_SECRET=dev-jwt-secret-key-change-in-production

# Embedding Configuration
SMRTI_EMBEDDING_PROVIDER=sentence_transformers
SMRTI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Features
SMRTI_ENABLE_HOT_RELOAD=true
SMRTI_ENABLE_METRICS=true

# Logging
SMRTI_LOG_LEVEL=DEBUG