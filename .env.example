# Smrti v2.0 Configuration
# Copy this file to .env and customize for your environment

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# API Configuration
API_KEYS=dev-key-123,dev-key-456
CORS_ORIGINS=*

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_WORKING_TTL=300
REDIS_SHORT_TERM_TTL=3600
REDIS_MAX_CONNECTIONS=50

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=smrti_
QDRANT_VECTOR_SIZE=384

# PostgreSQL Configuration
POSTGRES_URL=postgresql://smrti:smrti@localhost:5432/smrti
POSTGRES_MIN_POOL_SIZE=5
POSTGRES_MAX_POOL_SIZE=20

# Embedding Configuration
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_CACHE_SIZE=1000
EMBEDDING_BATCH_SIZE=32

# Validation Configuration
MAX_TEXT_LENGTH=50000
MAX_METADATA_SIZE=10240
