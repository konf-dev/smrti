def create_test_record(
    record_id: str,
    text: str,
    tenant_id: str = "test_tenant",
    namespace: str = "test_ns",
    metadata: Dict[str, Any] = None,
    embedding: List[float] = None,
    created_at: datetime = None
) -> RecordEnvelope:
    """Utility function to create test record envelopes."""
    return RecordEnvelope(
        record_id=record_id,
        tenant_id=tenant_id,
        namespace=namespace,
        content=TextContent(text=text),
        metadata=metadata or {},
        embedding=embedding,
        created_at=created_at or datetime.utcnow()
    )


def create_test_query(
    query_text: str,
    tenant_id: str = "test_tenant",
    namespace: str = "test_ns",
    limit: int = 10,
    **kwargs
) -> MemoryQuery:
    """Utility function to create test memory queries."""
    return MemoryQuery(
        query_text=query_text,
        tenant_id=tenant_id,
        namespace=namespace,
        limit=limit,
        **kwargs
    )


class MockAsyncContext:
    """Mock async context manager for testing."""
    
    def __init__(self, return_value=None):
        self.return_value = return_value
        self.entered = False
        self.exited = False
    
    async def __aenter__(self):
        self.entered = True
        return self.return_value
    
    async def __aexit__(self, exc_type, exc_val, exc_tb):
        self.exited = True
        return False


class AsyncMockIterator:
    """Mock async iterator for testing."""
    
    def __init__(self, items: List[Any]):
        self.items = items
        self.index = 0
    
    def __aiter__(self):
        return self
    
    async def __anext__(self):
        if self.index >= len(self.items):
            raise StopAsyncIteration
        item = self.items[self.index]
        self.index += 1
        return item


def assert_records_equal(record1: RecordEnvelope, record2: RecordEnvelope):
    """Assert that two record envelopes are equal."""
    assert record1.record_id == record2.record_id
    assert record1.tenant_id == record2.tenant_id
    assert record1.namespace == record2.namespace
    assert record1.content.get_text() == record2.content.get_text()
    assert record1.metadata == record2.metadata


def assert_queries_equal(query1: MemoryQuery, query2: MemoryQuery):
    """Assert that two memory queries are equal."""
    assert query1.query_text == query2.query_text
    assert query1.tenant_id == query2.tenant_id
    assert query1.namespace == query2.namespace
    assert query1.limit == query2.limit
    assert query1.similarity_threshold == query2.similarity_threshold