# ==============================================================================
# SMRTI MEMORY SYSTEM - DOCKER ENVIRONMENT CONFIGURATION
# Copy this file to .env and customize for your environment
# ==============================================================================

# ==============================================================================
# CORE APPLICATION SETTINGS
# ==============================================================================

# Application
SMRTI_LOG_LEVEL=info
SMRTI_DEBUG=false
SMRTI_HOST=0.0.0.0
SMRTI_PORT=8000

# Feature flags
SMRTI_FEATURE_ENABLE_RERANK=true
SMRTI_FEATURE_ENABLE_GRAPH=true
SMRTI_FEATURE_ENABLE_FACT_EXTRACTION=true
SMRTI_FEATURE_ENABLE_ENTITY_RESOLUTION=true
SMRTI_FEATURE_ADAPTIVE_WEIGHTS=true

# Context assembly
SMRTI_CONTEXT_DEFAULT_BUDGET=8000
SMRTI_CONTEXT_MAX_BUDGET=32000

# Memory tier configuration
SMRTI_TIER_WORKING_BACKEND=redis
SMRTI_TIER_SHORT_TERM_BACKEND=redis
SMRTI_TIER_LONG_TERM_BACKEND=chroma
SMRTI_TIER_EPISODIC_BACKEND=postgres
SMRTI_TIER_SEMANTIC_BACKEND=neo4j

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# Redis (Working & Short-term Memory)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5.0

# PostgreSQL (Episodic Memory)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smrti
POSTGRES_USER=smrti
POSTGRES_PASSWORD=smrti_password
POSTGRES_URL=postgresql://smrti:smrti_password@postgres:5432/smrti
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Neo4j (Semantic Memory)
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smrti_password
NEO4J_URI=bolt://neo4j:7687
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# ChromaDB (Vector Storage)
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=/data/chroma
CHROMA_COLLECTION_NAME=smrti_vectors
CHROMA_URL=http://chroma:8000

# ==============================================================================
# EMBEDDING & AI CONFIGURATION
# ==============================================================================

# Default embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_SIZE=10000
EMBEDDING_BATCH_SIZE=100

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Cohere (optional)
COHERE_API_KEY=
COHERE_MODEL=command-r

# Enterprise vector stores (optional)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
WEAVIATE_URL=
QDRANT_URL=

# ==============================================================================
# OBSERVABILITY & MONITORING
# ==============================================================================

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_HOST=0.0.0.0
PROMETHEUS_PORT=9090
PROMETHEUS_ENDPOINT=http://prometheus:9090

# OpenTelemetry tracing
OTEL_ENABLED=true
OTEL_SERVICE_NAME=smrti-memory-system
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:14268/api/traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Structured logging
STRUCTLOG_LEVEL=info
STRUCTLOG_FORMAT=json
LOG_FILE_PATH=/app/logs/smrti.log

# ==============================================================================
# SECURITY & PRIVACY
# ==============================================================================

# PII redaction
ENABLE_PII_REDACTION=true
PII_REDACTION_PATTERNS=email,phone,ssn

# Encryption (optional)
ENCRYPTION_ENABLED=false
ENCRYPTION_KEY_PATH=
KMS_KEY_ID=

# CORS settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================

# Query performance
MAX_QUERY_TIMEOUT_MS=5000
MAX_RETRIEVAL_RESULTS=100
DEFAULT_SIMILARITY_THRESHOLD=0.7

# Batch processing
MAX_BATCH_SIZE=1000
BATCH_FLUSH_INTERVAL_MS=1000

# Caching
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL=300
ENABLE_EMBEDDING_CACHE=true
EMBEDDING_CACHE_TTL=3600

# Connection pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
REDIS_CONNECTION_POOL_SIZE=20

# ==============================================================================
# DEVELOPMENT SETTINGS
# ==============================================================================

# Development mode
DEV_MODE=true
AUTO_RELOAD=true
DEBUG_SQL=false
DEBUG_REDIS=false

# Testing
TEST_DATABASE_URL=postgresql://smrti:smrti_password@postgres:5432/smrti_test
TEST_REDIS_URL=redis://redis:6379/1

# Sample data
LOAD_SAMPLE_DATA=true
SAMPLE_DATA_SIZE=small  # small, medium, large

# ==============================================================================
# DOCKER COMPOSE OVERRIDES
# ==============================================================================

# Service memory limits (for docker-compose)
REDIS_MEMORY_LIMIT=2g
POSTGRES_MEMORY_LIMIT=4g
NEO4J_MEMORY_LIMIT=4g
CHROMA_MEMORY_LIMIT=2g
SMRTI_APP_MEMORY_LIMIT=4g

# Volume paths (customize for your system)
DATA_DIR=./data
LOGS_DIR=./logs
CONFIG_DIR=./config

# Network settings
DOCKER_NETWORK_SUBNET=172.20.0.0/16

# ==============================================================================
# PRODUCTION OVERRIDES
# ==============================================================================
# Uncomment and configure for production deployment

# Security
# SECRET_KEY=your-secret-key-here
# JWT_SECRET_KEY=your-jwt-secret-here

# SSL/TLS
# SSL_ENABLED=true
# SSL_CERT_PATH=/certs/smrti.crt
# SSL_KEY_PATH=/certs/smrti.key

# External services (production)
# REDIS_CLUSTER_NODES=redis1:6379,redis2:6379,redis3:6379
# POSTGRES_REPLICA_URL=postgresql://user:pass@replica-host:5432/smrti
# NEO4J_CLUSTER_URI=neo4j+s://cluster.databases.neo4j.io

# Resource limits (production)
# MAX_WORKERS=16
# WORKER_MEMORY_LIMIT=2g
# MAX_CONNECTIONS_PER_WORKER=100